#include <stdio.h>
#include <sys/stat.h>
#include <time.h>

int main()
{
    struct stat file;

    if (stat("student.txt", &file) == -1)
    {
        printf("File not found.\n");
        return 1;
    }

    printf("File Size: %ld bytes\n", file.st_size);

    printf("File Permissions: %o\n", file.st_mode & 0777);

    printf("Last Modified: %s", ctime(&file.st_mtime));

    return 0;
}
