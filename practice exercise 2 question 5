#include <stdio.h>
#include <unistd.h>
#include <sys/wait.h>
#include <stdlib.h>

int main()
{
    int i;

    for(i = 0; i < 3; i++)
    {
        if(fork() == 0)
        {
            printf("Child %d: PID = %d, PPID = %d\n", i + 1, getpid(), getppid());
            exit(0);
        }
    }

    for(i = 0; i < 3; i++)
        wait(NULL);

    printf("Parent: PID = %d\n", getpid());

    return 0;
}
