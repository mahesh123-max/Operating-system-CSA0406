#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <string.h>

int main()
{
    int fd;
    char name[50];

    printf("Enter student name: ");
    fgets(name, sizeof(name), stdin);

    fd = open("student.txt", O_WRONLY | O_CREAT | O_TRUNC, 0644);

    if (fd < 0)
    {
        printf("File opening failed.\n");
        return 1;
    }

    write(fd, name, strlen(name));

    close(fd);

    printf("Name written to student.txt successfully.\n");

    return 0;
}
