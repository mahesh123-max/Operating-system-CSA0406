#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>
#include <sys/wait.h>
int main() {
    pid_t pid1, pid2;
    pid1 = fork();
    if (pid1 < 0) {
        printf("First fork failed!\n");
        return 1;
    }
    if (pid1 == 0) {
        printf("First Child: PID = %d, Parent PID = %d\n", getpid(), getppid());
        return 0;
    }
    pid2 = fork();
    if (pid2 < 0) {
        printf("Second fork failed!\n");
        return 1;
    }
    if (pid2 == 0) {
        printf("Second Child: PID = %d, Parent PID = %d\n", getpid(), getppid());
        return 0;
    }
    printf("Parent: PID = %d\n", getpid());
    wait(NULL);
    wait(NULL);
    return 0;
}
